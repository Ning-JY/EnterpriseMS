{
  "ConnectionStrings": {
    "Default": "Server=127.0.0.1;Port=3306;Database=enterprise_db;Uid=root;Pwd=123456;CharSet=utf8mb4;AllowPublicKeyRetrieval=true;"
  },
  "Redis": {
    "Connection": "127.0.0.1:6379,password=123456,abortConnect=false"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "Hangfire": {
    "ContractWarningDays": 30,
    "CertWarningDays": 60
  },
  "App": {
    "Name": "企业管理系统",
    "UploadPath": "wwwroot/uploads/"
  },
  "AllowedHosts": "*",
  "Cookie": {
    "SecurePolicy": "SameAsRequest",
    "_comment": "可选值: SameAsRequest(推荐,自动适配HTTP和HTTPS) | Always(纯HTTPS) | None(纯HTTP)"
  }
}
