@section Scripts {
<script>
var antiForgery = '@Html.AntiForgeryToken()'.match(/value="([^"]+)"/)[1];
var projId = @Model.Id;

// ── Tab 保持：用 sessionStorage 存当前 Tab，强制 reload 后恢复 ──
$(function() {
    // 恢复上次的 Tab（优先 sessionStorage，其次 URL hash）
    var savedTab = sessionStorage.getItem('projDetailTab_@Model.Id');
    var hashTab  = window.location.hash;
    var restoreTab = savedTab || hashTab;
    if (restoreTab) {
        var tabLink = $('a[data-toggle="tab"][href="' + restoreTab + '"]');
        if (tabLink.length) {
            tabLink.tab('show');
        }
    }
    // 切换时记录当前 Tab
    $('a[data-toggle="tab"]').on('shown.bs.tab', function(e) {
        sessionStorage.setItem('projDetailTab_@Model.Id', e.target.hash);
    });
});

function reloadWithTab() {
    // 先把当前激活的 Tab 存入 sessionStorage，再强制刷新
    var activeTab = $('a[data-toggle="tab"].active').attr('href');
    if (activeTab) {
        sessionStorage.setItem('projDetailTab_@Model.Id', activeTab);
    }
    location.reload(true);  // true = 强制从服务器重新加载，不走缓存
}

// ── 移除成员 ─────────────────────────────────────────────────
function removeMember(memberId, name) {
    layer.confirm('确认移除成员 <b>' + name + '</b>？移除后可重新添加。',
        {icon:3, title:'移除确认', btn:['确认移除','取消']}, function(i) {
        layer.close(i);
        $.post('/project/' + projId + '/members/' + memberId + '/remove',
            {__RequestVerificationToken: antiForgery},
            function(r) { handleResult(r, reloadWithTab); });
    });
}

// ── 状态变更 ────────────────────────────────────────────────
function saveStatus() {
    ajaxPost('/project/status', {
        Id: projId, NewStatus: parseInt($('#newStatus').val()),
        StatusDate: $('#statusDate').val(), Remark: $('#statusRemark').val()
    }, function(r) {
        layer.msg(r.message, {icon:1, time:1500}, function() {
            $('#statusModal').modal('hide'); reloadWithTab();
        });
    });
}

// ── 成员管理 ────────────────────────────────────────────────
function saveMember() {
    var ratio = parseFloat($('#addRatio').val());
    if (!$('#addEmpId').val()) { layer.msg('请选择员工', {icon:2}); return; }
    if (!ratio) { layer.msg('请填写占比', {icon:2}); return; }
    ajaxPost('/project/@Model.Id/members', {
        EmployeeId: parseInt($('#addEmpId').val()),
        Role: $('#addRole').val(), DutyDesc: $('#addDuty').val(),
        Ratio: ratio, JoinDate: $('#addJoinDate').val()
    }, function(r) {
        layer.msg(r.message, {icon:1, time:1500}, function() {
            $('#addMemberModal').modal('hide'); reloadWithTab();
        });
    });
}

function openEditMember(id, role, duty, ratio) {
    $('#editMemberId').val(id);
    $('#editMemberRole').val(role);
    $('#editMemberDuty').val(duty);
    $('#editMemberRatio').val(ratio);
    $('#editMemberModal').modal('show');
}

function saveEditMember() {
    var ratio = parseFloat($('#editMemberRatio').val());
    if (!ratio) { layer.msg('请填写占比', {icon:2}); return; }
    ajaxPost('/project/members/update', {
        Id: parseInt($('#editMemberId').val()),
        Role: $('#editMemberRole').val(),
        DutyDesc: $('#editMemberDuty').val(),
        Ratio: ratio
    }, function(r) {
        layer.msg(r.message, {icon:1, time:1500}, function() {
            $('#editMemberModal').modal('hide'); reloadWithTab();
        });
    });
}

// ── 里程碑 ──────────────────────────────────────────────────
function openEditMs(id, name, type, planDate, sort, remark) {
    $('#msModalTitle').text('编辑工作节点');
    $('#editMsId').val(id);
    $('#msName').val(name); $('#msType').val(type);
    $('#msPlanDate').val(planDate); $('#msSort').val(sort);
    $('#msRemark').val(remark); $('#msAmount').val('');
    $('#addMsModal').modal('show');
}

function saveMs() {
    if (!$('#msName').val()) { layer.msg('请填写节点名称', {icon:2}); return; }
    if (!$('#msPlanDate').val()) { layer.msg('请选择计划日期', {icon:2}); return; }
    var id = $('#editMsId').val();
    var url = id ? '/project/milestones/update' : '/project/@Model.Id/milestones';
    var data = {
        MilestoneName: $('#msName').val(), MilestoneType: $('#msType').val(),
        PlanDate: $('#msPlanDate').val(), Sort: parseInt($('#msSort').val())||1,
        AcceptAmount: parseFloat($('#msAmount').val())||null,
        Remark: $('#msRemark').val()
    };
