        // ── 文件选择（不立即上传）──────────────────────────────────
        function onFileSelected(input) {
            if (!input.files[0]) return;
            var file = input.files[0];

            // 生成默认版本号：V月.日，如 V04.10
            var now = new Date();
            var month = String(now.getMonth() + 1).padStart(2, '0');
            var day   = String(now.getDate()).padStart(2, '0');
            var defaultVersion = 'V' + month + '.' + day;

            // 默认版本号（若用户未手动填写才覆盖）
            if (!$('#uploadVersion').val()) {
                $('#uploadVersion').val(defaultVersion);
            }

            // 默认说明为文件名（去掉扩展名）
            if (!$('#uploadDesc').val()) {
                var nameWithoutExt = file.name.replace(/\.[^/.]+$/, '');
                $('#uploadDesc').val(nameWithoutExt);
            }

            // 显示预览信息
            var sizeText = file.size < 1048576
                ? (file.size / 1024).toFixed(1) + ' KB'
                : (file.size / 1048576).toFixed(1) + ' MB';

            $('#previewFileName').text(file.name);
            $('#previewFileSize').text('(' + sizeText + ')');
            $('#previewCategory').text($('#uploadCategory').val());
            $('#previewVersion').text($('#uploadVersion').val() || '未填写');
            $('#previewDesc').text($('#uploadDesc').val() || '未填写');
            $('#uploadPreview').show();
        }

        // 类别/版本/说明变化时同步更新预览
        $(function() {
            $('#uploadCategory, #uploadVersion, #uploadDesc').on('input change', function() {
                if ($('#uploadPreview').is(':visible')) {
                    $('#previewCategory').text($('#uploadCategory').val());
                    $('#previewVersion').text($('#uploadVersion').val() || '未填写');
                    $('#previewDesc').text($('#uploadDesc').val() || '未填写');
                }
            });
        });

        // ── 取消选择 ─────────────────────────────────────────────
        function clearFileSelection() {
            $('#fileInput').val('');
            $('#uploadVersion').val('');
            $('#uploadDesc').val('');
            $('#uploadPreview').hide();
        }

        // ── 确认上传（真正提交）───────────────────────────────────
        function confirmUpload() {
            var input = document.getElementById('fileInput');
            if (!input.files[0]) {
                layer.msg('请先选择文件', {icon: 2});
                return;
            }
            var formData = new FormData();
            formData.append('file',     input.files[0]);
            formData.append('category', $('#uploadCategory').val());
            formData.append('description', $('#uploadDesc').val());
            formData.append('version',  $('#uploadVersion').val());

            $('#uploadConfirmBtn').prop('disabled', true)
                .html('<i class="fas fa-spinner fa-spin mr-1"></i> 上传中...');

            var load = layer.load(1);
            $.ajax({
                url: '/project/' + projId + '/files',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                headers: {'RequestVerificationToken': antiForgery},
                success: function(r) {
                    layer.close(load);
                    $('#uploadConfirmBtn').prop('disabled', false)
                        .html('<i class="fas fa-upload mr-1"></i> 确认上传');
                    if (r.success) {
                        layer.msg('上传成功', {icon: 1, time: 1500}, function() {
                            clearFileSelection();
                            reloadWithTab();
                        });
                    } else {
                        layer.msg(r.message || '上传失败', {icon: 2});
                    }
                },
                error: function() {
                    layer.close(load);
                    $('#uploadConfirmBtn').prop('disabled', false)
                        .html('<i class="fas fa-upload mr-1"></i> 确认上传');
                    layer.msg('网络请求失败，请重试', {icon: 2});
                }
            });
        }

        // ── 删除文件 ─────────────────────────────────────────────
        function deleteFile(fileId) {
            layer.confirm('确认删除该文件？', {icon: 3}, function(i) {
                layer.close(i);
                $.post('/project/files/delete/' + fileId,
                    {__RequestVerificationToken: antiForgery}, function(r) {
                    layer.msg(r.message, {icon: r.success ? 1 : 2, time: 1500},
                        function() { if (r.success) reloadWithTab(); });
                });
            });
        }
</script>
}

@functions {
    string GetFileIcon(string? ext) => ext?.ToLower() switch {
        "pdf"  => "fa-file-pdf text-danger",
        "doc" or "docx" => "fa-file-word text-primary",
        "xls" or "xlsx" => "fa-file-excel text-success",
        "jpg" or "jpeg" or "png" => "fa-file-image text-warning",
        "zip" or "rar" => "fa-file-archive text-secondary",
        _ => "fa-file text-muted"
    };
}
