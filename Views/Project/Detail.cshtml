@using EnterpriseMS.Common.Extensions
@using EnterpriseMS.Services.DTOs.Project
@using EnterpriseMS.Services.DTOs.Hr
@model ProjectDetailDto
@inject EnterpriseMS.Services.Interfaces.IPermissionService PermSvc
@{
    ViewData["Title"] = Model.ProjName;
    var userId     = User.GetUserId();
    bool canEdit   = await PermSvc.HasPermAsync(userId, "proj:project:edit");
    bool canStatus = await PermSvc.HasPermAsync(userId, "proj:project:status");
    bool canMember = await PermSvc.HasPermAsync(userId, "proj:member:add");
    bool canMSAdd  = await PermSvc.HasPermAsync(userId, "proj:milestone:add");
    bool canAccept = await PermSvc.HasPermAsync(userId, "proj:acceptance:add");
    var members    = ViewBag.AllMembers as List<EmployeeSimpleDto> ?? new();
    string[] statusText = {"前期商务","预计启动","标书制作中","投标/磋商中",
                            "已中标·签合同中","已签回合同","执行中","成果提交","已完成","已终止"};
    string[] statusBadge= {"secondary","info","warning","warning",
                            "primary","primary","success","success","success","danger"};
    var dicts = ViewBag.DictMilestoneType as List<EnterpriseMS.Services.DTOs.System.DictDataDto> ?? new();
}

<div class="content-header">
  <div class="container-fluid">
    <div class="row mb-2">
      <div class="col-sm-7">
        <h1 class="m-0">
          <a href="/project" class="text-muted mr-2"><i class="fas fa-arrow-left"></i></a>
          @Model.ProjName
          <span class="badge badge-@statusBadge[Model.ProgressStatus] ml-2">
            @statusText[Model.ProgressStatus]
          </span>
        </h1>
        <small class="text-muted ml-4">@Model.ProjNo
          @if (Model.StatusUpdatedAt.HasValue)
          { <span class="ml-3"><i class="fas fa-clock mr-1"></i>状态更新：@Model.StatusUpdatedAt.Value.ToString("yyyy-MM-dd HH:mm")</span> }
        </small>
      </div>
      <div class="col-sm-5 text-right">
        @if (canEdit) {
          <a href="/project/edit/@Model.Id" class="btn btn-sm btn-warning mr-1">
            <i class="fas fa-edit"></i> 编辑
          </a>
        }
        @if (canStatus && Model.ProgressStatus < 9) {
          <button class="btn btn-sm btn-primary" data-toggle="modal" data-target="#statusModal">
            <i class="fas fa-arrow-right"></i> 变更状态
          </button>
        }
      </div>
    </div>
  </div>
</div>

<section class="content"><div class="container-fluid">

<!-- 顶部摘要 -->
<div class="row mb-3">
  <div class="col-md-3">
    <div class="info-box shadow-sm">
      <span class="info-box-icon bg-primary"><i class="fas fa-file-contract"></i></span>
      <div class="info-box-content">
        <span class="info-box-text">合同金额</span>
        <span class="info-box-number">¥@Model.ContractAmount.ToString("N2")万</span>
        @if (Model.IsJointVenture) { <small class="text-white-50">联合体·我方@Model.OurRatio%</small> }
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="info-box shadow-sm">
      <span class="info-box-icon bg-success"><i class="fas fa-hand-holding-usd"></i></span>
      <div class="info-box-content">
        <span class="info-box-text">已收款</span>
        <span class="info-box-number">¥@Model.TotalReceived.ToString("N2")万</span>
        @{ var rate = Model.ActualAmount > 0 ? Model.TotalReceived / Model.ActualAmount * 100 : 0; }
        <small class="text-white-50">收款率 @rate.ToString("N1")%</small>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="info-box shadow-sm">
      <span class="info-box-icon bg-warning"><i class="fas fa-tasks"></i></span>
      <div class="info-box-content">
        <span class="info-box-text">里程碑</span>
        <span class="info-box-number">@Model.MilestoneDone / @Model.MilestoneTotal</span>
        <small class="text-white-50">已完成/共计</small>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="info-box shadow-sm">
      <span class="info-box-icon bg-info"><i class="fas fa-users"></i></span>
      <div class="info-box-content">
        <span class="info-box-text">服务团队</span>
        <span class="info-box-number">@Model.Members.Count(m=>m.Status==0) 人</span>
        <small class="text-white-50">合计占比 @Model.Members.Where(m=>m.Status==0).Sum(m=>m.Ratio).ToString("N1")%</small>
      </div>
    </div>
  </div>
</div>

<!-- ═══ 固定卡片区 ═══ -->

<!-- 固定卡片①：基本信息 + 合同管理 -->
<div class="row">
  <div class="col-md-7">
    <div class="card card-primary card-outline">
      <div class="card-header">
        <h3 class="card-title"><i class="fas fa-info-circle mr-1"></i>基本信息</h3>
        @if (canEdit) {
          <div class="card-tools">
            <a href="/project/edit/@Model.Id" class="btn btn-xs btn-warning">
              <i class="fas fa-edit"></i> 编辑
            </a>
          </div>
        }
      </div>
      <div class="card-body" id="tab-basic">

        <div class="row">
          <div class="col-md-6">
            <table class="table table-sm table-borderless">
              <tr><td class="text-muted" width="35%">业务类型</td><td>@Model.BizType</td></tr>
              <tr><td class="text-muted">采购方式</td><td>@(Model.ProcurementType??"-")</td></tr>
              <tr><td class="text-muted">项目业主</td><td><strong>@Model.OwnerName</strong></td></tr>
              <tr><td class="text-muted">业主联系人</td><td>@(Model.OwnerContact??"-") @Model.OwnerPhone</td></tr>
              <tr><td class="text-muted">限价金额</td><td>@(Model.LimitPrice.HasValue?$"¥{Model.LimitPrice:N2}万":"-")</td></tr>
              <tr><td class="text-muted">建设规模</td><td>@(Model.BuildingScale??"-")</td></tr>
            </table>
          </div>
          <div class="col-md-6">
            <table class="table table-sm table-borderless">
              <tr><td class="text-muted" width="35%">承接部门</td><td>@(Model.DeptName??"-")</td></tr>
              <tr><td class="text-muted">技术负责人</td><td>@(Model.TechLeaderName??"-")</td></tr>
              <tr><td class="text-muted">商务负责人</td><td>@(Model.BizLeaderName??"-")</td></tr>
              <tr><td class="text-muted">签约日期</td><td>@(Model.SignDate?.ToString("yyyy-MM-dd")??"-")</td></tr>
              <tr><td class="text-muted">计划完成</td><td>@(Model.PlanEndDate?.ToString("yyyy-MM-dd")??"-")</td></tr>
              <tr><td class="text-muted">实际完成</td><td>@(Model.ActualEndDate?.ToString("yyyy-MM-dd")??"-")</td></tr>
            </table>
          </div>
        </div>
        @if (!string.IsNullOrEmpty(Model.Remark))
        { <div class="alert alert-light border-left border-primary"><i class="fas fa-info-circle mr-2"></i>@Model.Remark</div> }
      </div>
    </div>
  </div>
  <!-- 固定卡片②：服务团队与产值 -->
  <div class="col-md-5">
    <div class="card card-success card-outline">
      <div class="card-header">
        <h3 class="card-title"><i class="fas fa-users mr-1"></i>服务团队与产值</h3>
        @{ var totalR = Model.Members.Where(m=>m.Status==0).Sum(m=>m.Ratio); }
        <span class="ml-2 small @(Math.Abs(totalR-100)<0.1m?"text-success":"text-warning")">
          已分配 @totalR.ToString("N1")%
        </span>
        @if (canMember)
        {
          <div class="card-tools">
            <button class="btn btn-xs btn-success" data-toggle="modal" data-target="#addMemberModal">
              <i class="fas fa-plus"></i>
            </button>
          </div>
        }
      </div>
      <div class="card-body p-0">
        <table class="table table-sm table-hover mb-0">
          <thead class="thead-light">
            <tr><th>姓名</th><th>角色</th><th>占比</th><th>合同产值</th><th>已实现</th><th>操作</th></tr>
          </thead>
          <tbody>
            @foreach (var m in Model.Members.OrderByDescending(x=>x.Status==0))
            {
              <tr class="@(m.Status==1?"table-secondary":"")">
                <td>
                  <strong>@m.EmployeeName</strong>
                  <br><small class="text-muted">@(m.DeptName??"")</small>
                </td>
                <td><small>@m.Role</small></td>
                <td><strong class="@(m.Status==0?"text-primary":"text-muted")">@m.Ratio.ToString("N1")%</strong></td>
                <td class="text-primary small">@m.ContractValue.ToString("N2")</td>
                <td class="text-success small">@m.ReceivedValue.ToString("N2")</td>
                <td>
                  @if (canMember && m.Status == 0)
                  {
                    <button class="btn btn-xs btn-info mr-1"
                        onclick="openEditMember(@m.Id,'@m.Role','@(m.DutyDesc??"")',@m.Ratio)"
                        title="编辑">
                      <i class="fas fa-edit"></i>
                    </button>
                    <button class="btn btn-xs btn-danger"
                        onclick="removeMember(@m.Id,'@m.EmployeeName')"
                        title="移除">
                      <i class="fas fa-user-minus"></i>
                    </button>
                  }
                </td>
              </tr>
            }
            @if (!Model.Members.Any())
            { <tr><td colspan="6" class="text-center text-muted py-3">暂无成员</td></tr> }
          </tbody>
          <tfoot class="table-active">
            <tr>
              <td colspan="3" class="font-weight-bold">合计</td>
              <td class="font-weight-bold text-primary">¥@Model.ActualAmount.ToString("N2")万</td>
              <td class="font-weight-bold text-success">¥@Model.TotalReceived.ToString("N2")万</td>
              <td></td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>
  </div>
</div>

<!-- 固定卡片③：合同管理 -->
<div class="card card-warning card-outline">
  <div class="card-header">
    <h3 class="card-title"><i class="fas fa-file-contract mr-1"></i>合同管理</h3>
    @if (canEdit)
    {
      <div class="card-tools">
        <button class="btn btn-xs btn-warning" data-toggle="modal" data-target="#addContractModal">
          <i class="fas fa-plus"></i> 新增合同
        </button>
      </div>
    }
  </div>
  <div class="card-body p-0">
    <table class="table table-sm mb-0">
      <thead class="thead-light">
        <tr><th>合同编号</th><th>类型</th><th>甲方</th><th>合同金额(万)</th><th>签约日期</th><th>状态</th><th>附件</th><th>操作</th></tr>
      </thead>
      <tbody>
        @foreach (var ct in Model.Contracts)
        {
          <tr>
            <td><code class="small">@ct.ContractNo</code></td>
            <td><span class="badge badge-light">@ct.ContractType</span></td>
            <td class="small">@ct.PartyA</td>
            <td class="text-primary font-weight-bold">¥@ct.Amount.ToString("N2")</td>
            <td class="small">@(ct.SignDate?.ToString("yyyy-MM-dd")??"-")</td>
            <td>
              @if (ct.Status==1) { <span class="badge badge-success">生效</span> }
              else { <span class="badge badge-secondary">无效</span> }
            </td>
            <td>
              @if (ct.FileName != null)
              {
                <div class="d-flex align-items-center">
                  <a href="/project/contracts/download/@ct.Id"
                     class="btn btn-xs btn-info mr-1" title="下载">
                    <i class="fas fa-download"></i>
                  </a>
                  @if (canEdit)
                  {
                    <label class="btn btn-xs btn-warning mb-0 mr-1" title="重新上传">
                      <i class="fas fa-sync-alt"></i>
                      <input type="file" style="display:none"
                             onchange="uploadContractFile(@ct.Id,this)">
                    </label>
                    <button class="btn btn-xs btn-outline-danger"
                            onclick="delContractFile(@ct.Id)" title="删除附件">
                      <i class="fas fa-times"></i>
                    </button>
                  }
                </div>
                <small class="text-muted d-block" style="font-size:11px">
                  @(ct.FileName.Length>16?ct.FileName[..16]+"…":ct.FileName)
                </small>
              }
              else if (canEdit)
              {
                <label class="btn btn-xs btn-outline-secondary mb-0">
                  <i class="fas fa-upload"></i>
                  <input type="file" style="display:none"
                         onchange="uploadContractFile(@ct.Id,this)">
                </label>
              }
            </td>
            <td>
              @if (canEdit)
              {
                <button class="btn btn-xs btn-danger"
                        onclick="delContract(@ct.Id,'@ct.ContractNo')">
                  <i class="fas fa-trash"></i>
                </button>
              }
            </td>
          </tr>
        }
        @if (!Model.Contracts.Any())
        { <tr><td colspan="8" class="text-center text-muted py-3">暂无合同记录</td></tr> }
      </tbody>
    </table>
  </div>
</div>

<!-- ═══ Tab 选项卡区 ═══ -->
<div class="card">
  <div class="card-header p-0">
    <ul class="nav nav-tabs" id="projTabs" role="tablist">
      <li class="nav-item"><a class="nav-link active" data-toggle="tab" href="#tab-milestone">工作节点</a></li>
      <li class="nav-item"><a class="nav-link" data-toggle="tab" href="#tab-file">项目文件</a></li>
      <li class="nav-item"><a class="nav-link" data-toggle="tab" href="#tab-receipt">回款管理</a></li>
      <li class="nav-item"><a class="nav-link" data-toggle="tab" href="#tab-log">操作日志</a></li>
    </ul>
  </div>
  <div class="card-body tab-content">

    <!-- ── Tab①：工作节点 ── -->
    <div class="tab-pane fade show active" id="tab-milestone">
      <div class="text-right mb-2">
        @if (canMSAdd)
        { <button class="btn btn-sm btn-success" data-toggle="modal" data-target="#addMsModal">
            <i class="fas fa-plus"></i> 新增节点
          </button> }
      </div>
      @if (Model.Milestones.Any())
      {
        <div class="timeline">
          @foreach (var ms in Model.Milestones.OrderBy(m=>m.Sort))
          {
            string msIcon = ms.Status==2 ? "fas fa-check bg-success"
                          : ms.IsOverdue  ? "fas fa-exclamation bg-danger"
                          : ms.Status==1  ? "fas fa-spinner bg-warning"
                          : "far fa-circle bg-secondary";
            <div>
              <i class="@msIcon"></i>
              <div class="timeline-item">
                <div class="timeline-header d-flex justify-content-between">
                  <span class="font-weight-bold">@ms.MilestoneName</span>
                  <div>
                    @if (ms.IsOverdue && ms.Status!=2)
                    { <span class="badge badge-danger mr-1">已逾期</span> }
                    @if (!string.IsNullOrEmpty(ms.MilestoneType))
                    { <span class="badge badge-info mr-1">@ms.MilestoneType</span> }
                    @if (canMSAdd)
                    {
                      <button class="btn btn-xs btn-info mr-1"
                        onclick="openEditMs(@ms.Id,'@ms.MilestoneName','@(ms.MilestoneType??"")',
                          '@ms.PlanDate.ToString("yyyy-MM-dd")','@ms.Sort','@(ms.Remark??"")')">
                        <i class="fas fa-edit"></i>
                      </button>
                      @if (ms.Status != 2)
                      {
                        <button class="btn btn-xs btn-success"
                          onclick="completeMs(@ms.Id)">完成</button>
                      }
                    }
                  </div>
                </div>
                <div class="timeline-body small text-muted">
                  计划：@ms.PlanDate.ToString("yyyy-MM-dd")
                  @if (ms.ActualDate.HasValue) { <span class="ml-3 text-success">实际：@ms.ActualDate.Value.ToString("yyyy-MM-dd")</span> }
                  @if (ms.OwnerName != null) { <span class="ml-3">负责人：@ms.OwnerName</span> }
                  @if (ms.AcceptAmount.HasValue) { <span class="ml-3 text-warning">应收：¥@ms.AcceptAmount.Value.ToString("N2")万</span> }
                  @if (!string.IsNullOrEmpty(ms.Remark)) { <div class="mt-1">@ms.Remark</div> }
                </div>
              </div>
            </div>
          }
          <div><i class="fas fa-flag bg-gray"></i></div>
        </div>
      }
      else { <div class="text-center text-muted py-4">暂无工作节点</div> }
    </div>

    <!-- 验收与回款 -->
    <!-- ── Tab②：回款管理（含验收+发票合并）── -->
    <div class="tab-pane fade" id="tab-receipt">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
          <span class="text-muted small mr-3">
            开票合计：<strong class="text-primary">¥@Model.Invoices.Sum(i=>i.Amount).ToString("N2")万</strong>
          </span>
          <span class="text-muted small">
            已收款：<strong class="text-success">¥@Model.Invoices.Where(i=>i.IsReceived).Sum(i=>i.Amount).ToString("N2")万</strong>
          </span>
        </div>
        @if (canEdit)
        {
          <button class="btn btn-sm btn-success" data-toggle="modal" data-target="#addReceiptModal">
            <i class="fas fa-plus"></i> 新增回款记录
          </button>
        }
      </div>
      <div class="table-responsive">
        <table class="table table-sm table-hover">
          <thead class="thead-light">
            <tr>
              <th>回款批次</th><th>发票号</th><th>发票类型</th>
              <th>金额(万)</th><th>税率</th><th>开票日期</th><th>付款方</th>
              <th>回款状态</th><th>发票附件</th><th>付款申请</th><th>操作</th>
            </tr>
          </thead>
          <tbody>
            @foreach (var inv in Model.Invoices.OrderByDescending(i=>i.CreatedAt))
            {
              <tr class="@(inv.IsReceived?"table-success":"")">
                <td><strong>@inv.ReceiptName</strong></td>
                <td><code class="small">@(inv.InvoiceNo??"-")</code></td>
                <td><small>@inv.InvoiceType</small></td>
                <td class="font-weight-bold text-primary">¥@inv.Amount.ToString("N2")</td>
                <td class="small">@(inv.TaxRate.HasValue?inv.TaxRate.Value.ToString("N1")+"%":"-")</td>
                <td class="small">@(inv.InvoiceDate?.ToString("yyyy-MM-dd")??"-")</td>
                <td class="small">@(inv.Payer??"-")</td>
                <td>
                  @if (inv.IsReceived)
                  {
                    <span class="badge badge-success">
                      <i class="fas fa-check mr-1"></i>已收款 @(inv.ReceivedDate?.ToString("yyyy-MM-dd"))
                    </span>
                  }
                  else if (canEdit)
                  {
                    <button class="btn btn-xs btn-outline-success" onclick="confirmReceived(@inv.Id)">
                      <i class="fas fa-check"></i> 确认收款
                    </button>
                  }
                  else
                  {
                    <span class="badge badge-warning">待收款</span>
                  }
                </td>
                <td>
                  @if (inv.InvoiceFileName != null)
                  {
                    <a href="/project/invoices/file/@inv.Id/invoice" class="text-info small">
                      <i class="fas fa-file-invoice"></i>
                      @(inv.InvoiceFileName.Length>10?inv.InvoiceFileName[..10]+"…":inv.InvoiceFileName)
                    </a>
                  }
                  else if (canEdit)
                  {
                    <label class="btn btn-xs btn-outline-secondary mb-0">
                      <i class="fas fa-upload"></i>
                      <input type="file" style="display:none"
                             onchange="uploadInvoiceFile(@inv.Id,'invoice',this)">
                    </label>
                  }
                </td>
                <td>
                  @if (inv.PaymentFileName != null)
                  {
                    <a href="/project/invoices/file/@inv.Id/payment" class="text-warning small">
                      <i class="fas fa-file-alt"></i>
                      @(inv.PaymentFileName.Length>10?inv.PaymentFileName[..10]+"…":inv.PaymentFileName)
                    </a>
                  }
                  else if (canEdit)
                  {
                    <label class="btn btn-xs btn-outline-secondary mb-0">
                      <i class="fas fa-upload"></i>
                      <input type="file" style="display:none"
                             onchange="uploadInvoiceFile(@inv.Id,'payment',this)">
                    </label>
                  }
                </td>
                <td>
                  @if (canEdit)
                  {
                    <button class="btn btn-xs btn-danger" onclick="delReceipt(@inv.Id)">
                      <i class="fas fa-trash"></i>
                    </button>
                  }
                </td>
              </tr>
            }
            @if (!Model.Invoices.Any())
            { <tr><td colspan="11" class="text-center text-muted py-4">暂无回款记录</td></tr> }
          </tbody>
          @if (Model.Invoices.Any())
          {
            <tfoot class="table-active">
              <tr>
                <td colspan="3" class="font-weight-bold">合计</td>
                <td class="font-weight-bold text-primary">¥@Model.Invoices.Sum(i=>i.Amount).ToString("N2")</td>
                <td colspan="3"></td>
                <td class="font-weight-bold text-success">
                  已收 ¥@Model.Invoices.Where(i=>i.IsReceived).Sum(i=>i.Amount).ToString("N2")
                </td>
                <td colspan="3"></td>
              </tr>
            </tfoot>
          }
        </table>
      </div>
    </div>
    <!-- ── Tab③：项目文件 ── -->
    <div class="tab-pane fade" id="tab-file">

    @if (canEdit)
    {
        <div class="mb-3 p-3 border rounded bg-light">
            <div class="row align-items-end">
                <div class="col-md-3">
                    <label class="small">文件类别</label>
                    <select id="uploadCategory" class="form-control form-control-sm">
                        <option value="资料收集">📁 资料收集</option>
                        <option value="过程文件">📄 过程文件</option>
                        <option value="成果文件">✅ 成果文件</option>
                        <option value="其他">📎 其他</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="small">版本号</label>
                    <input type="text" id="uploadVersion" class="form-control form-control-sm"
                            placeholder="如 V04.10">
                </div>
                <div class="col-md-3">
                    <label class="small">文件说明</label>
                    <input type="text" id="uploadDesc" class="form-control form-control-sm"
                            placeholder="默认使用文件名">
                </div>
                <div class="col-md-3">
                    <label class="btn btn-sm btn-outline-secondary mb-0 w-100" style="cursor:pointer">
                        <i class="fas fa-folder-open mr-1"></i> 选择文件
                        <input type="file" id="fileInput" style="display:none"
                                onchange="onFileSelected(this)">
                    </label>
                </div>
            </div>

            <!-- 文件预览区（选择后显示） -->
            <div id="uploadPreview" class="mt-2" style="display:none;">
                <div class="alert alert-info py-2 mb-2">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <i class="fas fa-file mr-2"></i>
                            <strong id="previewFileName"></strong>
                            <span class="text-muted ml-2" id="previewFileSize"></span>
                        </div>
                        <button type="button" class="btn btn-xs btn-outline-secondary"
                                onclick="clearFileSelection()">
                            <i class="fas fa-times"></i> 取消
                        </button>
                    </div>
                    <div class="mt-1 small text-muted">
                        类别：<span id="previewCategory"></span> &nbsp;|&nbsp;
                        版本：<span id="previewVersion"></span> &nbsp;|&nbsp;
                        说明：<span id="previewDesc"></span>
                    </div>
                </div>
                <button type="button" class="btn btn-sm btn-success" id="uploadConfirmBtn"
                        onclick="confirmUpload()">
                    <i class="fas fa-upload mr-1"></i> 确认上传
                </button>
            </div>
        </div>
    }

    @{
        var fileGroups = Model.Files.GroupBy(f => f.FileCategory).OrderBy(g => g.Key);
    }
    @foreach (var grp in fileGroups)
    {
        <h6 class="font-weight-bold text-muted mt-3 mb-2">
            @(grp.Key == "资料收集" ? "📁" : grp.Key == "过程文件" ? "📄" : grp.Key == "成果文件" ? "✅" : "📎")
            @grp.Key（@grp.Count()个）
        </h6>
        <table class="table table-sm table-hover">
            <thead class="thead-light">
                <tr><th>文件名</th><th>版本</th><th>大小</th><th>说明</th><th>上传人</th><th>上传时间</th><th>操作</th></tr>
            </thead>
            <tbody>
                @foreach (var f in grp.OrderByDescending(x => x.CreatedAt))
                {
                    <tr>
                        <td>
                            <i class="fas @GetFileIcon(f.FileExt) mr-1 text-muted"></i>
                            <a href="/project/files/download/@f.Id">@f.FileName</a>
                        </td>
                        <td class="small">@(f.Version ?? "-")</td>
                        <td class="small text-muted">@f.FileSizeText</td>
                        <td class="small text-muted">@(f.Description ?? "-")</td>
                        <td class="small">@f.UploadBy</td>
                        <td class="small text-muted">@f.CreatedAt.ToString("MM-dd HH:mm")</td>
                        <td>
                            <a href="/project/files/download/@f.Id" class="btn btn-xs btn-outline-primary">
                                <i class="fas fa-download"></i>
                            </a>
                            @if (canEdit)
                            {
                                <button class="btn btn-xs btn-outline-danger ml-1"
                                        onclick="deleteFile(@f.Id)">
                                    <i class="fas fa-trash"></i>
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    @if (!Model.Files.Any())
    {
        <div class="text-center text-muted py-4">暂无文件</div>
    }
</div>
    <!-- 操作日志 -->
    <div class="tab-pane fade" id="tab-log">
      <div class="timeline">
        @foreach (var log in Model.Logs.OrderByDescending(l=>l.OperAt))
        {
          <div>
            <i class="fas fa-history bg-secondary"></i>
            <div class="timeline-item">
              <span class="time text-muted small">
                <i class="fas fa-clock mr-1"></i>@log.OperAt.ToString("yyyy-MM-dd HH:mm")
                &nbsp;@log.OperBy
              </span>
              <h3 class="timeline-header font-weight-normal">@log.Title</h3>
              @if (!string.IsNullOrEmpty(log.Content))
              { <div class="timeline-body small text-muted">@log.Content</div> }
            </div>
          </div>
        }
        @if (!Model.Logs.Any())
        { <div class="text-center text-muted py-4">暂无操作日志</div> }
        <div><i class="fas fa-flag bg-gray"></i></div>
      </div>
    </div>

  </div><!-- tab-content -->
</div><!-- card -->

</div></section>

