@using EnterpriseMS.Services.DTOs.Project
@using EnterpriseMS.Services.DTOs.System
@using EnterpriseMS.Services.DTOs.Hr
@model ProjectDetailDto
@{
    ViewData["Title"] = "编辑项目 - " + Model.ProjName;
    var depts   = ViewBag.Depts   as List<DeptTreeDto>          ?? new();
    var members = ViewBag.Members as List<EmployeeSimpleDto>    ?? new();
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">
                    <a href="/project/@Model.Id" class="text-muted mr-2">
                        <i class="fas fa-arrow-left"></i>
                    </a>
                    编辑项目
                    <small class="text-muted font-weight-normal ml-2">@Model.ProjNo</small>
                </h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="/">首页</a></li>
                    <li class="breadcrumb-item"><a href="/project">项目台账</a></li>
                    <li class="breadcrumb-item"><a href="/project/@Model.Id">@Model.ProjName</a></li>
                    <li class="breadcrumb-item active">编辑</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<section class="content"><div class="container-fluid">

<div class="card card-primary card-outline">
    <div class="card-header"><h3 class="card-title">基本信息</h3></div>
    <div class="card-body">
        <div class="form-group">
            <label>项目名称 <span class="text-danger">*</span></label>
            <input type="text" id="projName" class="form-control"
                   value="@Model.ProjName" maxlength="200">
        </div>
        <div class="row">
            <div class="col-md-4">
                <div class="form-group">
                    <label>业务类型 <span class="text-danger">*</span></label>
                    <select id="bizType" class="form-control">
                        @{
                            string[] bizTypes = {
                                "可行性研究报告","节能评估报告","稳评报告",
                                "概算编制","预算编制","结算编制",
                                "概算评审","预算评审","结算评审",
                                "控制性详细规划","专项规划","城市更新规划",
                                "施工图设计","战略咨询","施工阶段全过程管控"
                            };
                        }
                        @foreach (var t in bizTypes)
                        {
                            <option value="@t" selected="@(Model.BizType == t ? "selected" : null)">@t</option>
                        }
                    </select>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group">
                    <label>承接部门</label>
                    <select id="deptId" class="form-control">
                        <option value="">请选择</option>
                        @foreach (var d in depts)
                        {
                            <option value="@d.Id" selected="@(Model.DeptId == d.Id ? "selected" : null)">@d.DeptName</option>
                            @foreach (var c in d.Children)
                            {
                                <option value="@c.Id" selected="@(Model.DeptId == c.Id ? "selected" : null)">&nbsp;&nbsp;└ @c.DeptName</option>
                            }
                        }
                    </select>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group">
                    <label>采购方式</label>
                    <select id="procurementType" class="form-control">
                        <option value="">请选择</option>
                        @{
                            string[] procTypes = { "竞争性磋商","询价","公开招标","邀请招标","公开招选","框架协议采购","单一来源" };
                        }
                        @foreach (var t in procTypes)
                        {
                            <option value="@t" selected="@(Model.ProcurementType == t ? "selected" : null)">@t</option>
                        }
                    </select>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card card-primary card-outline">
    <div class="card-header"><h3 class="card-title">业主方信息</h3></div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-4">
                <div class="form-group">
                    <label>项目业主 <span class="text-danger">*</span></label>
                    <input type="text" id="ownerName" class="form-control"
                           value="@Model.OwnerName" maxlength="100">
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group">
                    <label>业主联系人</label>
                    <input type="text" id="ownerContact" class="form-control"
                           value="@(Model.OwnerContact ?? "")">
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group">
                    <label>联系人手机</label>
                    <input type="text" id="ownerPhone" class="form-control"
                           value="@(Model.OwnerPhone ?? "")">
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card card-primary card-outline">
    <div class="card-header"><h3 class="card-title">合同与金额</h3></div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-3">
                <div class="form-group">
                    <label>限价金额（万元）</label>
                    <input type="number" id="limitPrice" class="form-control"
                     step="0.01" value="@(Model.LimitPrice?.ToString("N4") ?? "")">
                </div>
            </div>
            <div class="col-md-3">
                <div class="form-group">
                    <label>合同金额（万元）<span class="text-danger">*</span></label>
                    <input type="number" id="contractAmount" class="form-control"
                    step="0.01" value="@Model.ContractAmount.ToString("N4")">
                </div>
            </div>
            <div class="col-md-3">
                <div class="form-group">
                    <label>签约日期</label>
                    <input type="date" id="signDate" class="form-control"
                           value="@(Model.SignDate?.ToString("yyyy-MM-dd") ?? "")">
                </div>
            </div>
            <div class="col-md-3">
                <div class="form-group">
                    <label>计划完成日期</label>
                    <input type="date" id="planEndDate" class="form-control"
                           value="@(Model.PlanEndDate?.ToString("yyyy-MM-dd") ?? "")">
                </div>
            </div>
        </div>
        <div class="custom-control custom-switch mb-3">
            <input type="checkbox" class="custom-control-input" id="isJointVenture"
                   @(Model.IsJointVenture ? "checked" : "")
                   onchange="$('#jointBlock').toggle(this.checked)">
            <label class="custom-control-label" for="isJointVenture">联合体项目</label>
        </div>
        <div id="jointBlock" style="@(Model.IsJointVenture ? "" : "display:none")"
             class="alert alert-light border">
            <div class="form-group mb-0" style="max-width:200px">
                <label>我方占比 <span class="text-danger">*</span></label>
                <div class="input-group">
                    <input type="number" id="ourRatio" class="form-control"
                           min="1" max="99" step="0.5"
                                   value="@(Model.OurRatio?.ToString("N2") ?? "")">
                    <div class="input-group-append"><span class="input-group-text">%</span></div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card card-primary card-outline">
    <div class="card-header"><h3 class="card-title">服务团队</h3></div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-4">
                <div class="form-group">
                    <label>技术负责人</label>
                    <select id="techLeaderId" class="form-control">
                        <option value="">请选择</option>
                        @foreach (var m in members)
                        {
                            <option value="@m.Id" selected="@(Model.TechLeaderId == m.Id ? "selected" : null)">@m.Display</option>
                        }
                    </select>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group">
                    <label>商务负责人</label>
                    <select id="bizLeaderId" class="form-control">
                        <option value="">请选择</option>
                        @foreach (var m in members)
                        {
                            <option value="@m.Id" selected="@(Model.BizLeaderId == m.Id ? "selected" : null)">@m.Display</option>
                        }
                    </select>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group">
                    <label>建设规模</label>
                    <input type="text" id="buildingScale" class="form-control"
                           value="@(Model.BuildingScale ?? "")">
                </div>
            </div>
        </div>
        <div class="form-group">
            <label>备注</label>
            <textarea id="remark" class="form-control" rows="2">@(Model.Remark ?? "")</textarea>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between mb-4">
    <a href="/project/@Model.Id" class="btn btn-default">
        <i class="fas fa-times mr-1"></i> 取消
    </a>
    <button type="button" class="btn btn-primary" onclick="submitUpdate()">
        <i class="fas fa-save mr-1"></i> 保存修改
    </button>
</div>

</div></section>

@section Scripts {
<script>
var antiForgery = '@Html.AntiForgeryToken()'.match(/value="([^"]+)"/)[1];
var projId = @Model.Id;

function submitUpdate() {
    var data = {
        Id:              projId,
        ProjName:        $('#projName').val(),
        ProjNo:          '@Model.ProjNo',
        DeptId:          parseInt($('#deptId').val()) || null,
        BizType:         $('#bizType').val(),
        OwnerName:       $('#ownerName').val(),
        OwnerContact:    $('#ownerContact').val(),
        OwnerPhone:      $('#ownerPhone').val(),
        ProcurementType: $('#procurementType').val(),
        LimitPrice:      parseFloat($('#limitPrice').val()) || null,
        ContractAmount:  parseFloat($('#contractAmount').val()),
        IsJointVenture:  $('#isJointVenture').is(':checked'),
        OurRatio:        parseFloat($('#ourRatio').val()) || null,
        TechLeaderId:    parseInt($('#techLeaderId').val()) || null,
        BizLeaderId:     parseInt($('#bizLeaderId').val()) || null,
        SignDate:        $('#signDate').val() || null,
        PlanEndDate:     $('#planEndDate').val() || null,
        ProgressStatus:  @Model.ProgressStatus,
        BuildingScale:   $('#buildingScale').val(),
        Remark:          $('#remark').val(),
        Members:         [],
        Milestones:      [],
    };
    if (!data.ProjName) { layer.msg('请填写项目名称', {icon:2}); return; }
    if (!data.OwnerName){ layer.msg('请填写项目业主', {icon:2}); return; }
    if (!data.ContractAmount){ layer.msg('请填写合同金额', {icon:2}); return; }

    ajaxPost('/project/update', data, function(r) {
        layer.msg(r.message, {icon:1, time:1500}, function() {
            window.location.href = '/project/' + projId;
        });
    });
}
</script>
}
