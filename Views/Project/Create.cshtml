@using EnterpriseMS.Services.DTOs.System
@{
    ViewData["Title"] = "新建项目";
    Layout = "_Layout";
    var depts   = ViewBag.Depts   as List<DeptTreeDto> ?? new List<DeptTreeDto>();
    var members = ViewBag.Members as List<EnterpriseMS.Services.DTOs.Hr.EmployeeSimpleDto>
                  ?? new List<EnterpriseMS.Services.DTOs.Hr.EmployeeSimpleDto>();
    var projNo  = ViewBag.ProjNo  as string ?? "";
}
<div class="content-header">
  <div class="container-fluid">
    <div class="row mb-2">
      <div class="col-sm-6">
        <h1 class="m-0">
          <a href="/project" class="text-muted mr-2"><i class="fas fa-arrow-left"></i></a>新建项目
        </h1>
      </div>
      <div class="col-sm-6">
        <ol class="breadcrumb float-sm-right">
          <li class="breadcrumb-item"><a href="/">首页</a></li>
          <li class="breadcrumb-item"><a href="/project">项目管理</a></li>
          <li class="breadcrumb-item active">新建项目</li>
        </ol>
      </div>
    </div>
  </div>
</div>
<section class="content">
<div class="container-fluid">
<form id="createProjForm">
@Html.AntiForgeryToken()

<!-- 步骤条 -->
<div class="card mb-3">
  <div class="card-body py-2">
    <div class="d-flex align-items-center">
      <span id="st1" class="badge badge-primary p-2 mr-2">1 基本信息</span>
      <div class="flex-fill border-top mx-2"></div>
      <span id="st2" class="badge badge-secondary p-2 mr-2">2 服务团队</span>
      <div class="flex-fill border-top mx-2"></div>
      <span id="st3" class="badge badge-secondary p-2">3 工作节点</span>
    </div>
  </div>
</div>

<!-- STEP 1 -->
<div id="step-1">
  <div class="card card-primary card-outline">
    <div class="card-header"><h3 class="card-title">基本信息</h3></div>
    <div class="card-body">
      <div class="row">
        <div class="col-md-6">
          <div class="form-group">
            <label>承接部门 <span class="text-danger">*</span></label>
            <select id="deptId" class="form-control">
              <option value="">请选择承接部门</option>
              @foreach (var d in depts)
              {
                <option value="@d.Id">@d.DeptName</option>
                @foreach (var c in d.Children)
                { <option value="@c.Id">&nbsp;&nbsp;@c.DeptName</option> }
              }
            </select>
          </div>
        </div>
        <div class="col-md-6">
          <div class="form-group">
            <label>业务类型 <span class="text-danger">*</span></label>
            <select id="bizType" class="form-control" onchange="onBizTypeChange()">
              <option value="">请选择</option>
              <optgroup label="工程咨询">
                <option>可行性研究报告</option><option>节能评估报告</option>
                <option>稳评报告</option><option>项目后评价</option>
                <option>概算编制</option><option>预算编制</option><option>结算编制</option>
                <option>概算评审</option><option>预算评审</option><option>结算评审</option>
              </optgroup>
              <optgroup label="规划设计">
                <option>控制性详细规划</option><option>专项规划</option>
                <option>城市更新规划</option><option>概念方案设计</option><option>施工图设计</option>
              </optgroup>
              <optgroup label="其他咨询">
                <option>战略咨询</option><option>专家评审服务</option><option>框架协议服务</option>
              </optgroup>
            </select>
          </div>
        </div>
      </div>
      <div class="form-group">
        <label>项目名称 <span class="text-danger">*</span></label>
        <input type="text" id="projName" class="form-control"
               placeholder="请输入完整项目名称，与合同文件保持一致" maxlength="200">
      </div>
      <div class="row">
        <div class="col-md-4">
          <div class="form-group">
            <label>项目编号</label>
            <input type="text" id="projNo" class="form-control" value="@projNo">
          </div>
        </div>
        <div class="col-md-4">
          <div class="form-group">
            <label>采购方式</label>
            <select id="procurementType" class="form-control">
              <option value="">请选择</option>
              <option>竞争性磋商</option><option>询价</option><option>公开招标</option>
              <option>邀请招标</option><option>公开招选</option>
              <option>框架协议采购</option><option>单一来源</option>
            </select>
          </div>
        </div>
        <div class="col-md-4">
          <div class="form-group">
            <label>当前进度状态 <span class="text-danger">*</span></label>
            <select id="progressStatus" class="form-control">
              <option value="0">前期商务</option><option value="1">预计启动</option>
              <option value="2">标书制作中</option><option value="3">投标/磋商中</option>
              <option value="4">已中标·签订合同中</option>
              <option value="5" selected>已签回合同</option><option value="6">执行中</option>
            </select>
          </div>
        </div>
      </div>
      <div class="row">
        <div class="col-md-4">
          <div class="form-group">
            <label>项目业主 <span class="text-danger">*</span></label>
            <input type="text" id="ownerName" class="form-control" placeholder="委托单位全称" maxlength="100">
          </div>
        </div>
        <div class="col-md-4">
          <div class="form-group">
            <label>业主联系人</label>
            <input type="text" id="ownerContact" class="form-control" placeholder="姓名">
          </div>
        </div>
        <div class="col-md-4">
          <div class="form-group">
            <label>联系人手机</label>
            <input type="text" id="ownerPhone" class="form-control" placeholder="手机号码">
          </div>
        </div>
      </div>
      <div class="row">
        <div class="col-md-3">
          <div class="form-group">
            <label>限价金额（万元）</label>
            <div class="input-group">
              <div class="input-group-prepend"><span class="input-group-text">¥</span></div>
              <input type="number" id="limitPrice" class="form-control" placeholder="选填" step="0.01" min="0">
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="form-group">
            <label>合同金额（万元）<span class="text-danger">*</span></label>
            <div class="input-group">
              <div class="input-group-prepend"><span class="input-group-text">¥</span></div>
              <input type="number" id="contractAmount" class="form-control"
                     placeholder="0.00" step="0.01" min="0" oninput="onAmountChange()">
              <div class="input-group-append"><span class="input-group-text">万</span></div>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="form-group">
            <label>开标/签约日期</label>
            <input type="date" id="signDate" class="form-control">
          </div>
        </div>
        <div class="col-md-3">
          <div class="form-group">
            <label>计划完成日期</label>
            <input type="date" id="planEndDate" class="form-control">
          </div>
        </div>
      </div>
      <div class="form-check mb-2">
        <input type="checkbox" class="form-check-input" id="isJointVenture"
               onchange="toggleJoint(this.checked)">
        <label class="form-check-label" for="isJointVenture">联合体项目</label>
      </div>
      <div id="jointArea" class="row" style="display:none">
        <div class="col-md-4">
          <div class="form-group">
            <label>我方合同占比 <span class="text-danger">*</span></label>
            <div class="input-group">
              <input type="number" id="ourRatio" class="form-control"
                     min="1" max="99" step="0.5" oninput="onAmountChange()">
              <div class="input-group-append"><span class="input-group-text">%</span></div>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="form-group">
            <label>我方实际合同额</label>
            <input type="text" id="actualAmt" class="form-control" readonly
                   style="background:#f8f9fa;font-weight:bold;color:#007bff">
          </div>
        </div>
      </div>
      <div class="form-group">
        <label>建设规模</label>
        <input type="text" id="buildingScale" class="form-control"
               placeholder="如：住宅12栋，建面8.6万㎡ / 道路改造2.3km">
      </div>
      <div class="form-group">
        <label>备注</label>
        <textarea id="remark" class="form-control" rows="2"
                  placeholder="如：开标截止时间、合同金额区间说明等"></textarea>
      </div>
    </div>
  </div>
  <div class="text-right mb-3">
    <button type="button" class="btn btn-primary" onclick="goStep(2)">
      下一步：服务团队 <i class="fas fa-arrow-right"></i>
    </button>
  </div>
</div>

<!-- STEP 2 -->
<div id="step-2" style="display:none">
  <div class="card card-success card-outline">
    <div class="card-header"><h3 class="card-title">固定角色</h3></div>
    <div class="card-body">
      <div class="row">
        <div class="col-md-6">
          <div class="form-group">
            <label>技术负责人</label>
            <select id="techLeaderId" class="form-control">
              <option value="">请选择</option>
              @foreach (var m in members)
              { <option value="@m.Id">@m.Display</option> }
            </select>
          </div>
        </div>
        <div class="col-md-6">
          <div class="form-group">
            <label>商务负责人</label>
            <select id="bizLeaderId" class="form-control">
              <option value="">请选择</option>
              @foreach (var m in members)
              { <option value="@m.Id">@m.Display</option> }
            </select>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="card card-success card-outline">
    <div class="card-header">
      <h3 class="card-title">参与人员 & 产值占比
        <span class="badge badge-light ml-2" id="amtDisplay">合同额：—</span>
      </h3>
      <div class="card-tools">
        <button type="button" class="btn btn-sm btn-success" onclick="addMRow()">
          <i class="fas fa-plus"></i> 添加
        </button>
      </div>
    </div>
    <div class="card-body p-0">
      <table class="table table-sm">
        <thead class="thead-light">
          <tr><th>姓名</th><th>职责描述</th><th width="130">占比</th><th width="110">产值</th><th width="36"></th></tr>
        </thead>
        <tbody id="mBody"></tbody>
      </table>
    </div>
    <div class="card-footer">
      占比合计：<strong id="rTotal" class="text-success">0%</strong>
      <span id="rWarn" class="text-danger ml-3" style="display:none">⚠ 须等于100%</span>
    </div>
  </div>
  <div class="d-flex justify-content-between mb-3">
    <button type="button" class="btn btn-default" onclick="goStep(1)">
      <i class="fas fa-arrow-left"></i> 上一步
    </button>
    <button type="button" class="btn btn-primary" onclick="goStep(3)">
      下一步：工作节点 <i class="fas fa-arrow-right"></i>
    </button>
  </div>
</div>

<!-- STEP 3 -->
<div id="step-3" style="display:none">
  <div class="card card-info card-outline">
    <div class="card-header">
      <h3 class="card-title">工作节点</h3>
      <div class="card-tools">
        <button type="button" class="btn btn-sm btn-info" onclick="addMsRow()">
          <i class="fas fa-plus"></i> 新增节点
        </button>
      </div>
    </div>
    <div class="card-body p-0">
      <table class="table table-sm">
        <thead class="thead-light">
          <tr><th>节点名称</th><th width="100">类型</th><th width="140">计划日期</th><th width="120">关联金额（万）</th><th width="36"></th></tr>
        </thead>
        <tbody id="msBody"></tbody>
      </table>
    </div>
  </div>
  <div class="callout callout-info" id="checkList">
    <h5>保存前检查</h5>
    <span id="ck1" class="mr-3">☐ 承接部门</span>
    <span id="ck2" class="mr-3">☐ 项目名称</span>
    <span id="ck3" class="mr-3">☐ 项目业主</span>
    <span id="ck4" class="mr-3">☐ 合同金额</span>
    <span id="ck5">☐ 成员占比</span>
  </div>
  <div class="d-flex justify-content-between mb-3">
    <button type="button" class="btn btn-default" onclick="goStep(2)">
      <i class="fas fa-arrow-left"></i> 上一步
    </button>
    <button type="button" class="btn btn-success" onclick="submitProj()">
      <i class="fas fa-check"></i> 提交保存
    </button>
  </div>
</div>

</form>
</div>
</section>

@section Scripts {
<script>
var af = '@Html.AntiForgeryToken()'.match(/value="([^"]+)"/)[1];
var allMembers = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
    members.Select(m => new { id = m.Id, name = m.RealName })));
var colors = ['#28a745','#007bff','#6f42c1','#fd7e14','#dc3545'];
var mIdx = 0, msIdx = 0;

function goStep(n) {
    $('[id^="step-"]').hide(); $('#step-'+n).show();
    ['st1','st2','st3'].forEach(function(id,i){
        $('#'+id).removeClass('badge-primary badge-secondary')
                 .addClass(i+1===n?'badge-primary':'badge-secondary');
    });
    if (n===2) { syncAmtDisplay(); updateRatios(); }
    if (n===3) { updateChecklist(); if (!$('#msBody tr').length) prefillMs(); }
    window.scrollTo(0,0);
}

function toggleJoint(on) { $('#jointArea').toggle(on); onAmountChange(); }

function onAmountChange() {
    var amt = parseFloat($('#contractAmount').val())||0;
    var isJ = $('#isJointVenture').is(':checked');
    var r   = parseFloat($('#ourRatio').val())||100;
    var act = isJ ? amt*r/100 : amt;
    if (isJ && amt>0) $('#actualAmt').val('¥ '+act.toFixed(2)+' 万');
    updateRatios(act);
}

function syncAmtDisplay() {
    var amt = parseFloat($('#contractAmount').val())||0;
    var isJ = $('#isJointVenture').is(':checked');
    var r   = parseFloat($('#ourRatio').val())||100;
    var act = isJ ? amt*r/100 : amt;
    $('#amtDisplay').text('合同额：'+(act>0?act.toFixed(2)+' 万':'—'));
}

function addMRow() {
    var i = mIdx++; var c = colors[i%colors.length];
    var opts = allMembers.map(function(m){
        return '<option value="'+m.id+'">'+m.name+'</option>';
    }).join('');
    $('#mBody').append('<tr id="mr'+i+'">' +
        '<td><select class="form-control form-control-sm mEmp"><option value="">请选择</option>'+opts+'</select></td>' +
        '<td><input type="text" class="form-control form-control-sm mDuty" placeholder="职责描述"></td>' +
        '<td><div class="input-group input-group-sm">' +
        '<input type="number" class="form-control mRatio" value="0" min="0" max="100" step="0.5" oninput="updateRatios()">' +
        '<div class="input-group-append"><span class="input-group-text">%</span></div></div>' +
        '<div class="progress progress-xs mt-1"><div class="progress-bar" style="width:0%;background:'+c+'" id="rb'+i+'"></div></div></td>' +
        '<td><strong class="text-primary mVal" id="mv'+i+'">—</strong></td>' +
        '<td><button type="button" class="btn btn-xs btn-danger" onclick="$(\'#mr'+i+'\').remove();updateRatios()"><i class="fas fa-times"></i></button></td>' +
        '</tr>');
}

function updateRatios(baseAmt) {
    if (baseAmt===undefined) {
        var amt=parseFloat($('#contractAmount').val())||0;
        var isJ=$('#isJointVenture').is(':checked');
        var r=parseFloat($('#ourRatio').val())||100;
        baseAmt=isJ?amt*r/100:amt;
    }
    var total=0;
    $('.mRatio').each(function(){ total+=parseFloat($(this).val())||0; });
    var ok=Math.abs(total-100)<0.1;
    $('#rTotal').text(total.toFixed(1)+'%').toggleClass('text-success',ok).toggleClass('text-danger',!ok);
    $('#rWarn').toggle(!ok);
    $('.mRatio').each(function(i){
        var r=parseFloat($(this).val())||0;
        var val=baseAmt>0?'¥ '+(baseAmt*r/100).toFixed(2)+' 万':'—';
        $(this).closest('tr').find('.mVal').text(val);
        $(this).closest('tr').find('.progress-bar').css('width',r+'%');
    });
}

function addMsRow(name,type,date) {
    var i=msIdx++;
    var types=['调研','方案','评审','报批','交付','回款'];
    var opts=types.map(function(t){ return '<option'+(t===type?' selected':'')+'>'+t+'</option>'; }).join('');
    $('#msBody').append('<tr id="msr'+i+'">' +
        '<td><input type="text" class="form-control form-control-sm msName" value="'+(name||'')+'" placeholder="节点名称"></td>' +
        '<td><select class="form-control form-control-sm msType">'+opts+'</select></td>' +
        '<td><input type="date" class="form-control form-control-sm msDate" value="'+(date||'')+'"></td>' +
        '<td><div class="input-group input-group-sm"><div class="input-group-prepend"><span class="input-group-text">¥</span></div>' +
        '<input type="number" class="form-control msAmt" placeholder="可选" step="0.01" min="0"></div></td>' +
        '<td><button type="button" class="btn btn-xs btn-danger" onclick="$(\'#msr'+i+'\').remove()"><i class="fas fa-times"></i></button></td>' +
        '</tr>');
}

function prefillMs() {
    var biz=$('#bizType').val();
    var presets={
        '控制性详细规划':[['现状调研','调研'],['方案初稿','方案'],['专家评审','评审'],['上报','报批'],['批复归档','交付']],
        '可行性研究报告':[['资料收集','调研'],['初稿提交','方案'],['评审修改','评审'],['成果交付','交付']],
        '施工图设计':    [['方案设计','方案'],['初步设计','方案'],['出图','交付'],['审查通过','交付']],
        '结算编制':      [['资料收集','调研'],['编制报告','方案'],['内审','评审'],['交付','交付']],
    };
    var nodes=presets[biz]||[['成果提交','交付']];
    nodes.forEach(function(n){ addMsRow(n[0],n[1]); });
}

function onBizTypeChange() {
    if (!$('#msBody tr').length) prefillMs();
}

function updateChecklist() {
    var checks={
        'ck1':!!$('#deptId').val(), 'ck2':!!$('#projName').val().trim(),
        'ck3':!!$('#ownerName').val().trim(), 'ck4':parseFloat($('#contractAmount').val())>0,
        'ck5':$('#mBody tr').length===0||Math.abs(getTotalRatio()-100)<0.1,
    };
    var labels={'ck1':'承接部门','ck2':'项目名称','ck3':'项目业主','ck4':'合同金额','ck5':'成员占比'};
    $.each(checks,function(id,ok){
        $('#'+id).text((ok?'✓ ':'☐ ')+labels[id])
                 .toggleClass('text-success',ok).toggleClass('text-muted',!ok);
    });
}

function getTotalRatio(){
    var t=0; $('.mRatio').each(function(){ t+=parseFloat($(this).val())||0; }); return t;
}

function collectData() {
    var ms_list=[]; $('#msBody tr').each(function(){
        var n=$(this).find('.msName').val(), d=$(this).find('.msDate').val();
        if(n&&d) ms_list.push({MilestoneName:n, MilestoneType:$(this).find('.msType').val(),
            PlanDate:d, AcceptAmount:parseFloat($(this).find('.msAmt').val())||null, Sort:ms_list.length+1});
    });
    var mb_list=[]; var s=1; $('#mBody tr').each(function(){
        var eid=$(this).find('.mEmp').val(), r=parseFloat($(this).find('.mRatio').val())||0;
        if(eid&&r>0) mb_list.push({EmployeeId:parseInt(eid), Role:'参与人员',
            DutyDesc:$(this).find('.mDuty').val(), Ratio:r,
            JoinDate:new Date().toISOString().split('T')[0]});
    });
    return {
        ProjNo:$('#projNo').val(), ProjName:$('#projName').val().trim(),
        DeptId:parseInt($('#deptId').val())||null, BizType:$('#bizType').val(),
        OwnerName:$('#ownerName').val().trim(), OwnerContact:$('#ownerContact').val(),
        OwnerPhone:$('#ownerPhone').val(), ProcurementType:$('#procurementType').val(),
        LimitPrice:parseFloat($('#limitPrice').val())||null,
        ContractAmount:parseFloat($('#contractAmount').val())||0,
        IsJointVenture:$('#isJointVenture').is(':checked'),
        OurRatio:parseFloat($('#ourRatio').val())||null,
        TechLeaderId:parseInt($('#techLeaderId').val())||null,
        BizLeaderId:parseInt($('#bizLeaderId').val())||null,
        SignDate:$('#signDate').val()||null, PlanEndDate:$('#planEndDate').val()||null,
        ProgressStatus:parseInt($('#progressStatus').val()),
        BuildingScale:$('#buildingScale').val(), Remark:$('#remark').val(),
        Members:mb_list, Milestones:ms_list,
    };
}

function submitProj() {
    var d=collectData();
    if(!d.BizType){layer.msg('请选择业务类型',{icon:2});goStep(1);return;}
    if(!d.ProjName){layer.msg('请填写项目名称',{icon:2});goStep(1);return;}
    if(!d.OwnerName){layer.msg('请填写项目业主',{icon:2});goStep(1);return;}
    if(d.ContractAmount<=0){layer.msg('请填写合同金额',{icon:2});goStep(1);return;}
    if(d.IsJointVenture&&!d.OurRatio){layer.msg('联合体须填写我方占比',{icon:2});goStep(1);return;}
    if(d.Members.length>0){
        var t=d.Members.reduce(function(s,m){return s+m.Ratio;},0);
        if(Math.abs(t-100)>0.1){layer.msg('成员占比总和须等于100%，当前'+t.toFixed(1)+'%',{icon:2});goStep(2);return;}
    }
    var load=layer.load(1);
    $.ajax({url:'/project/create',type:'POST',contentType:'application/json',
        headers:{'RequestVerificationToken':af}, data:JSON.stringify(d),
        success:function(r){
            layer.close(load);
            if(r.success){layer.msg('创建成功！',{icon:1,time:1500},function(){window.location='/project/'+r.data.id;});}
            else{layer.msg(r.message,{icon:2});}
        },
        error:function(){layer.close(load);layer.msg('请求失败',{icon:2});}
    });
}
</script>
}
