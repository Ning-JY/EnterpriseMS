@{
    Layout = null;
    ViewData["Title"] = "登录";
}
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>企业管理系统 - 登录</title>
    <link rel="stylesheet" href="~/lib/adminlte/css/adminlte.min.css">
    <link rel="stylesheet" href="~/lib/fontawesome/css/all.min.css">
    <style>
        body {
            background: #1e2d3d;
        }

        .login-box {
            margin-top: 8vh;
        }

        .login-card-body {
            border-top: 4px solid #007bff;
        }

        /* ── Demo 账号区域 ── */
        .demo-section {
            margin-top: 16px;
            padding-top: 14px;
            border-top: 1px dashed #dee2e6;
        }

        .demo-section-label {
            font-size: 11px;
            color: #adb5bd;
            text-align: center;
            margin-bottom: 10px;
            letter-spacing: 0.05em;
            text-transform: uppercase;
        }

        .demo-buttons {
            display: flex;
            gap: 8px;
        }

        .demo-btn {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            padding: 8px 4px;
            border: 1px solid #dee2e6;
            border-radius: 6px;
            background: #f8f9fa;
            cursor: pointer;
            transition: all 0.18s ease;
            font-size: 12px;
            color: #495057;
            line-height: 1.3;
        }

            .demo-btn:hover {
                border-color: #007bff;
                background: #e8f4ff;
                color: #007bff;
                transform: translateY(-2px);
                box-shadow: 0 3px 8px rgba(0, 123, 255, 0.15);
            }

            .demo-btn:active {
                transform: translateY(0);
                box-shadow: none;
            }

            .demo-btn .demo-icon {
                width: 28px;
                height: 28px;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 13px;
                color: #fff;
                flex-shrink: 0;
            }

            .demo-btn .demo-name {
                font-weight: 600;
                font-size: 12px;
            }

            .demo-btn .demo-account {
                font-size: 10px;
                color: #adb5bd;
            }

            .demo-btn:hover .demo-account {
                color: #74b9ff;
            }

            /* 三个按钮各自的图标背景色 */
            .demo-btn:nth-child(1) .demo-icon {
                background: #007bff;
            }

            .demo-btn:nth-child(2) .demo-icon {
                background: #28a745;
            }

            .demo-btn:nth-child(3) .demo-icon {
                background: #6c757d;
            }

            .demo-btn:nth-child(1):hover {
                border-color: #007bff;
                background: #e8f4ff;
                color: #007bff;
            }

            .demo-btn:nth-child(2):hover {
                border-color: #28a745;
                background: #e8f5e9;
                color: #28a745;
            }

            .demo-btn:nth-child(3):hover {
                border-color: #6c757d;
                background: #f0f0f0;
                color: #6c757d;
            }

            .demo-btn:nth-child(1):hover {
                box-shadow: 0 3px 8px rgba(0,123,255,0.15);
            }

            .demo-btn:nth-child(2):hover {
                box-shadow: 0 3px 8px rgba(40,167,69,0.15);
            }

            .demo-btn:nth-child(3):hover {
                box-shadow: 0 3px 8px rgba(108,117,125,0.15);
            }
    </style>
</head>
<body class="hold-transition login-page">
    <div class="login-box">
        
        <div class="card">
            <div class="login-logo">
                <b>企业</b>管理系统
            </div>
            <div class="card-body login-card-body">
                <p class="login-box-msg text-muted">请登录您的账号</p>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger alert-dismissible">
                        <button type="button" class="close" data-dismiss="alert">×</button>
                        @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <span>@err.ErrorMessage</span>
                        }
                    </div>
                }

                <form asp-action="Login" asp-controller="Account" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl">

                    <div class="input-group mb-3">
                        <input type="text" name="username" class="form-control"
                               placeholder="用户名" required autofocus>
                        <div class="input-group-append">
                            <div class="input-group-text">
                                <span class="fas fa-user"></span>
                            </div>
                        </div>
                    </div>
                    <div class="input-group mb-3">
                        <input type="password" name="password" class="form-control"
                               placeholder="密码" required>
                        <div class="input-group-append">
                            <div class="input-group-text">
                                <span class="fas fa-lock"></span>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-12">
                            <button type="submit" class="btn btn-primary btn-block">
                                <i class="fas fa-sign-in-alt mr-1"></i> 登 录
                            </button>
                        </div>
                    </div>
                </form>

                @* ── Demo 账号快捷登录 ──*@
                <div class="demo-section">
                    <div class="demo-section-label">快捷体验账号</div>
                    <div class="demo-buttons">
                        <button class="demo-btn" onclick="fillDemoAccount('admin','123456')">
                            <span class="demo-icon"><i class="fas fa-shield-alt"></i></span>
                            <span class="demo-name">管理员</span>
                            <span class="demo-account">admin</span>
                        </button>
                        <button class="demo-btn" onclick="fillDemoAccount('user','password')">
                            <span class="demo-icon"><i class="fas fa-user"></i></span>
                            <span class="demo-name">普通用户</span>
                            <span class="demo-account">user</span>
                        </button>
                        <button class="demo-btn" onclick="fillDemoAccount('test','test123')">
                            <span class="demo-icon"><i class="fas fa-flask"></i></span>
                            <span class="demo-name">测试用户</span>
                            <span class="demo-account">test</span>
                        </button>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <script src="~/lib/jquery/jquery.min.js"></script>
    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/adminlte/js/adminlte.min.js"></script>
    <script>
        function fillDemoAccount(username, password) {
            document.querySelector('input[name="username"]').value = username;
            document.querySelector('input[name="password"]').value = password;
        }
    </script>
</body>
</html>
