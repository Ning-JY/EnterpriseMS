@using EnterpriseMS.Services.DTOs.User
@model UserDetailDto
@{
    ViewData["Title"] = "个人中心";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6"><h1 class="m-0">个人中心</h1></div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="/">首页</a></li>
                    <li class="breadcrumb-item active">个人中心</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<section class="content"><div class="container-fluid">
<div class="row">
    <!-- 个人信息 -->
    <div class="col-md-4">
        <div class="card card-primary card-outline">
            <div class="card-body text-center">
                <div class="mb-3">
                    <i class="fas fa-user-circle fa-5x text-muted"></i>
                </div>
                <h4 class="mb-1">@Model.RealName</h4>
                <p class="text-muted mb-0">@(Model.DeptName ?? "暂无部门")</p>
                <p class="text-muted small">@(Model.PostName ?? "")</p>
            </div>
            <div class="card-footer p-0">
                <table class="table table-sm table-borderless mb-0">
                    <tr>
                        <td class="text-muted pl-3">用户名</td>
                        <td><code>@Model.Username</code></td>
                    </tr>
                    <tr>
                        <td class="text-muted pl-3">角色</td>
                        <td>
                            @foreach (var r in Model.RoleNames)
                            { <span class="badge badge-info mr-1">@r</span> }
                        </td>
                    </tr>
                    <tr>
                        <td class="text-muted pl-3">最后登录</td>
                        <td class="small">@(Model.LastLoginTime?.ToString("MM-dd HH:mm") ?? "首次登录")</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>

    <!-- 编辑信息 & 修改密码 -->
    <div class="col-md-8">
        <!-- 基本信息 -->
        <div class="card card-default">
            <div class="card-header">
                <h3 class="card-title">基本信息</h3>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>姓名 <span class="text-danger">*</span></label>
                            <input type="text" id="realName" class="form-control"
                                   value="@Model.RealName" maxlength="50">
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>手机号</label>
                            <input type="text" id="phone" class="form-control"
                                   value="@(Model.Phone ?? "")">
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <label>邮箱</label>
                    <input type="email" id="email" class="form-control"
                           value="@(Model.Email ?? "")">
                </div>
                <button type="button" class="btn btn-primary" onclick="saveProfile()">
                    <i class="fas fa-save mr-1"></i> 保存信息
                </button>
            </div>
        </div>

        <!-- 修改密码 -->
        <div class="card card-default">
            <div class="card-header">
                <h3 class="card-title">修改密码</h3>
            </div>
            <div class="card-body">
                <div class="form-group">
                    <label>原密码 <span class="text-danger">*</span></label>
                    <input type="password" id="oldPwd" class="form-control"
                           placeholder="请输入当前密码">
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>新密码 <span class="text-danger">*</span></label>
                            <input type="password" id="newPwd" class="form-control"
                                   placeholder="最少6位">
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>确认新密码 <span class="text-danger">*</span></label>
                            <input type="password" id="confirmPwd" class="form-control"
                                   placeholder="再次输入新密码">
                        </div>
                    </div>
                </div>
                <button type="button" class="btn btn-warning" onclick="changePwd()">
                    <i class="fas fa-key mr-1"></i> 修改密码
                </button>
            </div>
        </div>
    </div>
</div>
</div></section>

@section Scripts {
<script>
var antiForgery = '@Html.AntiForgeryToken()'.match(/value="([^"]+)"/)[1];

function saveProfile() {
    var data = {
        Id:       @Model.Id,
        RealName: $('#realName').val(),
        Phone:    $('#phone').val(),
        Email:    $('#email').val(),
        DeptId:   @(Model.DeptId?.ToString() ?? "null"),
        PostId:   null,
        RoleIds:  @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RoleIds)),
    };
    if (!data.RealName) { layer.msg('请填写姓名', {icon:2}); return; }
    ajaxPost('/system/user/update', data, function(r) {
        layer.msg(r.message, {icon:1, time:1500}, function() { location.reload(); });
    });
}

function changePwd() {
    var oldP = $('#oldPwd').val();
    var newP = $('#newPwd').val();
    var conf = $('#confirmPwd').val();
    if (!oldP || !newP) { layer.msg('请填写原密码和新密码', {icon:2}); return; }
    if (newP.length < 6) { layer.msg('新密码不能少于6位', {icon:2}); return; }
    if (newP !== conf)   { layer.msg('两次密码不一致', {icon:2}); return; }
    ajaxPost('/system/user/changepwd', { OldPassword: oldP, NewPassword: newP }, function(r) {
        layer.msg(r.message, {icon:1, time:1500}, function() {
            $('#oldPwd,#newPwd,#confirmPwd').val('');
        });
    });
}
</script>
}
