@using EnterpriseMS.Domain.Entities.Info
@model List<KbFile>
@{
    ViewData["Title"] = "知识库";
    var categories  = ViewBag.Categories as List<KbCategory> ?? new();
    var curCatId    = ViewBag.CategoryId as long?;
    string[] previewExts = { "pdf", "jpg", "jpeg", "png" };
    string FileSizeText(long size) => size < 1024 ? $"{size}B"
        : size < 1048576 ? $"{size/1024:N1}KB" : $"{size/1048576:N1}MB";
    string ExtIcon(string? ext) => (ext ?? "").ToLower() switch {
        "pdf"  => "fa-file-pdf text-danger",
        "doc" or "docx" => "fa-file-word text-primary",
        "xls" or "xlsx" => "fa-file-excel text-success",
        "ppt" or "pptx" => "fa-file-powerpoint text-warning",
        "jpg" or "jpeg" or "png" => "fa-file-image text-info",
        "zip" or "rar" => "fa-file-archive text-secondary",
        _ => "fa-file text-muted"
    };
}

<div class="content-header"><div class="container-fluid">
    <div class="row mb-2">
        <div class="col-sm-6"><h1 class="m-0">知识库</h1></div>
        <div class="col-sm-6">
            <ol class="breadcrumb float-sm-right">
                <li class="breadcrumb-item"><a href="/">首页</a></li>
                <li class="breadcrumb-item active">知识库</li>
            </ol>
        </div>
    </div>
</div></div>

<section class="content"><div class="container-fluid">
<div class="row">

    <!-- 左侧分类 -->
    <div class="col-md-3">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-folder mr-2"></i>文件分类</h3>
            </div>
            <div class="card-body p-0">
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a href="/kb" class="nav-link @(curCatId == null ? "active" : "")">
                            <i class="fas fa-layer-group mr-2"></i>全部文件
                            <span class="badge badge-secondary float-right">@ViewBag.Total</span>
                        </a>
                    </li>
                    @foreach (var cat in categories)
                    {
                        <li class="nav-item">
                            <a href="/kb?categoryId=@cat.Id"
                               class="nav-link @(curCatId == cat.Id ? "active" : "")">
                                <i class="fas @(cat.Icon ?? "fa-folder") mr-2"></i>@cat.Name
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
        <div class="card">
            <div class="card-body text-center">
                <a href="/kb/manage" class="btn btn-outline-secondary btn-sm btn-block">
                    <i class="fas fa-cog mr-1"></i> 文件管理
                </a>
            </div>
        </div>
    </div>

    <!-- 右侧文件列表 -->
    <div class="col-md-9">
        <!-- 搜索栏 -->
        <div class="card card-body p-2 mb-3">
            <form id="searchForm" method="get" action="/kb" class="d-flex">
                @if (curCatId.HasValue)
                {
                    <input type="hidden" name="categoryId" value="@curCatId">
                }
                <input name="keyword" class="form-control mr-2"
                       placeholder="搜索文件名或说明..." value="@ViewBag.Keyword">
                <input type="hidden" name="page" value="1">
                <button class="btn btn-primary px-4">
                    <i class="fas fa-search"></i>
                </button>
            </form>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="fas fa-folder-open fa-3x mb-3 d-block"></i>
                暂无文件
            </div>
        }
        else
        {
            <div class="card">
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="thead-light">
                            <tr>
                                <th style="width:40%">文件名称</th>
                                <th>分类</th>
                                <th>大小</th>
                                <th>版本</th>
                                <th>上传时间</th>
                                <th>下载次数</th>
                                <th>操作</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var f in Model)
                            {
                                <tr>
                                    <td>
                                        @if (f.IsPinned)
                                        {
                                            <span class="badge badge-danger mr-1">置顶</span>
                                        }
                                        <i class="fas @ExtIcon(f.FileExt) mr-2"></i>
                                        <strong>@f.FileName</strong>
                                        @if (!string.IsNullOrEmpty(f.Description))
                                        {
                                            <br><small class="text-muted">@f.Description</small>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge badge-light">
                                            @(f.Category?.Name ?? "-")
                                        </span>
                                    </td>
                                    <td class="small text-muted">@FileSizeText(f.FileSize)</td>
                                    <td class="small">@(f.Version ?? "-")</td>
                                    <td class="small text-muted">@f.CreatedAt.ToString("yyyy-MM-dd")</td>
                                    <td class="text-center">
                                        <span class="badge badge-light">@f.DownloadCount</span>
                                    </td>
                                    <td>
                                        @if (previewExts.Contains(f.FileExt?.ToLower() ?? ""))
                                        {
                                            <button class="btn btn-xs btn-info mr-1"
                                                    onclick="previewFile(@f.Id,'@f.FileName','@f.FileExt')"
                                                    title="预览">
                                                <i class="fas fa-eye"></i>
                                            </button>
                                        }
                                        <a href="/kb/download/@f.Id"
                                           class="btn btn-xs btn-primary" title="下载">
                                            <i class="fas fa-download"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                @{
                    var paged = new EnterpriseMS.Common.PagedResult<KbFile>
                    {
                        Items    = Model,
                        Total    = (int)(ViewBag.Total    ?? 0),
                        Page     = (int)(ViewBag.Page     ?? 1),
                        PageSize = (int)(ViewBag.Size      ?? 20),
                    };
                }
                <partial name="_Pagination" model="paged" />
            </div>
        }
    </div>
</div>
</div></section>

<!-- PDF/图片预览弹窗 -->
<div class="modal fade" id="previewModal" tabindex="-1">
    <div class="modal-dialog modal-xl" style="max-width:90vw">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title" id="previewTitle"></h6>
                <div class="ml-auto d-flex align-items-center">
                    <a id="previewDownload" href="#" class="btn btn-sm btn-primary mr-2">
                        <i class="fas fa-download mr-1"></i>下载
                    </a>
                    <button type="button" class="close ml-0" data-dismiss="modal">
                        <span>&times;</span>
                    </button>
                </div>
            </div>
            <div class="modal-body p-0" style="height:80vh">
                <iframe id="previewFrame" src="" style="width:100%;height:100%;border:none"></iframe>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function previewFile(id, name, ext) {
    $('#previewTitle').text(name);
    $('#previewDownload').attr('href', '/kb/download/' + id);
    $('#previewFrame').attr('src', '/kb/preview/' + id);
    $('#previewModal').modal('show');
}
// 关闭弹窗时清空iframe（避免占用内存）
$('#previewModal').on('hidden.bs.modal', function() {
    $('#previewFrame').attr('src', '');
});
</script>
}
