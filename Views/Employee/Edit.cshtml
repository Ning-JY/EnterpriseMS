@using EnterpriseMS.Domain.Entities.Hr
@using EnterpriseMS.Services.DTOs.System
@model Employee
@{
    ViewData["Title"] = "编辑员工 - " + Model.RealName;
    var depts = ViewBag.Depts as List<DeptTreeDto> ?? new();
    string[] statusText = { "试用期", "在职", "已离职" };
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">
                    <a href="/hr/employee/detail/@Model.Id" class="text-muted mr-2">
                        <i class="fas fa-arrow-left"></i>
                    </a>
                    编辑员工 - @Model.RealName
                </h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="/">首页</a></li>
                    <li class="breadcrumb-item"><a href="/hr/employee">员工信息</a></li>
                    <li class="breadcrumb-item"><a href="/hr/employee/detail/@Model.Id">@Model.RealName</a></li>
                    <li class="breadcrumb-item active">编辑</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<section class="content"><div class="container-fluid">
<div class="card card-primary card-outline">
    <div class="card-header"><h3 class="card-title">基本信息</h3></div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-3">
                <div class="form-group">
                    <label>工号</label>
                    <input type="text" class="form-control" value="@Model.EmpNo" readonly
                           style="background:#f8f9fa">
                </div>
            </div>
            <div class="col-md-3">
                <div class="form-group">
                    <label>姓名 <span class="text-danger">*</span></label>
                    <input type="text" id="realName" class="form-control"
                           value="@Model.RealName" maxlength="50">
                </div>
            </div>
            <div class="col-md-3">
                <div class="form-group">
                    <label>性别</label>
                    <select id="gender" class="form-control">
                        <option value="1" selected="@(Model.Gender == 1 ? "selected" : null)">男</option>
                        <option value="2" selected="@(Model.Gender == 2 ? "selected" : null)">女</option>
                    </select>
                </div>
            </div>
            <div class="col-md-3">
                <div class="form-group">
                    <label>状态</label>
                    <input type="text" class="form-control"
                           value="@statusText[Model.Status]" readonly style="background:#f8f9fa">
                    <small class="text-muted">状态通过转正/离职操作变更</small>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-4">
                <div class="form-group">
                    <label>手机号</label>
                    <input type="text" id="phone" class="form-control"
                           value="@(Model.Phone ?? "")">
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group">
                    <label>邮箱</label>
                    <input type="email" id="email" class="form-control"
                           value="@(Model.Email ?? "")">
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group">
                    <label>身份证号</label>
                    <input type="text" id="idCard" class="form-control"
                           value="@(Model.IdCard ?? "")" maxlength="18">
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-4">
                <div class="form-group">
                    <label>所属部门</label>
                    <select id="deptId" class="form-control">
                        <option value="">请选择</option>
                        @foreach (var d in depts)
                        {
                            <option value="@d.Id" selected="@(Model.DeptId == d.Id ? "selected" : null)">
                                @d.DeptName
                            </option>
                            @foreach (var cd in d.Children)
                            {
                                <option value="@cd.Id" selected="@(Model.DeptId == cd.Id ? "selected" : null)">
                                    &nbsp;&nbsp;└ @cd.DeptName
                                </option>
                            }
                        }
                    </select>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group">
                    <label>入职日期</label>
                    <input type="date" id="entryDate" class="form-control"
                           value="@(Model.EntryDate?.ToString("yyyy-MM-dd") ?? "")">
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group">
                    <label>试用期截止日</label>
                    <input type="date" id="probationEnd" class="form-control"
                           value="@(Model.ProbationEndDate?.ToString("yyyy-MM-dd") ?? "")">
                </div>
            </div>
        </div>
        <div class="form-group">
            <label>备注</label>
            <textarea id="remark" class="form-control" rows="2">@(Model.Remark ?? "")</textarea>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between mb-4">
    <a href="/hr/employee/detail/@Model.Id" class="btn btn-default">
        <i class="fas fa-times mr-1"></i> 取消
    </a>
    <button type="button" class="btn btn-primary" onclick="saveEdit()">
        <i class="fas fa-save mr-1"></i> 保存修改
    </button>
</div>

</div></section>

@section Scripts {
<script>
var antiForgery = '@Html.AntiForgeryToken()'.match(/value="([^"]+)"/)[1];
var empId = @Model.Id;

function saveEdit() {
    var data = {
        Id:               empId,
        RealName:         $('#realName').val(),
        Gender:           parseInt($('#gender').val()),
        Phone:            $('#phone').val(),
        Email:            $('#email').val(),
        IdCard:           $('#idCard').val(),
        DeptId:           parseInt($('#deptId').val()) || null,
        EntryDate:        $('#entryDate').val() || null,
        ProbationEndDate: $('#probationEnd').val() || null,
        Remark:           $('#remark').val()
    };
    if (!data.RealName) { layer.msg('请填写姓名', {icon:2}); return; }
    ajaxPost('/hr/employee/update', data, function(r) {
        layer.msg(r.message, {icon:1, time:1500}, function() {
            window.location.href = '/hr/employee/detail/' + empId;
        });
    });
}
</script>
}
