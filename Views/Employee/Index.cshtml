@using EnterpriseMS.Common.Extensions
@using EnterpriseMS.Services.DTOs.Hr
@model PagedResult<EmployeeListDto>
@inject EnterpriseMS.Services.Interfaces.IPermissionService PermSvc
@{
    ViewData["Title"] = "员工信息";
    var userId = User.GetUserId();
    bool canAdd    = await PermSvc.HasPermAsync(userId, "hr:employee:add");
    bool canEdit   = await PermSvc.HasPermAsync(userId, "hr:employee:edit");
    bool canFormal = await PermSvc.HasPermAsync(userId, "hr:employee:formal");
    bool canLeave  = await PermSvc.HasPermAsync(userId, "hr:employee:leave");
    string[] statusText  = ["试用期", "在职", "已离职"];
    string[] statusBadge = ["badge-warning", "badge-success", "badge-secondary"];
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6"><h1 class="m-0">员工信息</h1></div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="/">首页</a></li>
                    <li class="breadcrumb-item">员工档案</li>
                    <li class="breadcrumb-item active">员工信息</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<section class="content"><div class="container-fluid">
<div class="card">
    <div class="card-header">
        <h3 class="card-title">员工列表（共 @Model.Total 人）</h3>
        <div class="card-tools d-flex align-items-center gap-2">
                    <form id="searchForm" method="get" action="/hr/employee" class="d-inline-flex mr-2">
                <input name="keyword" class="form-control form-control-sm mr-1"
                       placeholder="姓名/工号/手机" value="@ViewBag.Query?.Keyword" style="width:160px">
                <select name="status" class="form-control form-control-sm mr-1" style="width:90px">
                    <option value="">全部</option>
                    <option value="0" selected="@(ViewBag.Query?.Status?.ToString()=="0" ? "selected" : null)">试用期</option>
                    <option value="1" selected="@(ViewBag.Query?.Status?.ToString()=="1" ? "selected" : null)">在职</option>
                    <option value="2" selected="@(ViewBag.Query?.Status?.ToString()=="2" ? "selected" : null)">离职</option>
                </select>
                <input type="hidden" name="page" id="pageInput" value="1">
                <button class="btn btn-sm btn-primary">搜索</button>
            </form>
            <a href="/hr/employee/export?keyword=@ViewBag.Query?.Keyword&deptId=@ViewBag.Query?.DeptId&status=@ViewBag.Query?.Status"
               class="btn btn-sm btn-success mr-1">
                <i class="fas fa-file-excel mr-1"></i>导出
            </a>
            <a href="/hr/employee/import" class="btn btn-sm btn-info mr-1">
                <i class="fas fa-file-import mr-1"></i>导入
            </a>
            @if (canAdd)
            {
                <button class="btn btn-sm btn-success" onclick="openAddModal()">
                    <i class="fas fa-plus"></i> 新增员工
                </button>
            }
        </div>
    </div>
    <div class="card-body table-responsive p-0">
        <table class="table table-hover table-sm">
            <thead class="thead-light">
                <tr>
                    <th>工号</th><th>姓名</th><th>部门</th><th>手机</th>
                    <th>状态</th><th>入职日期</th><th>转正日期</th><th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in Model.Items)
                {
                    <tr>
                        <td><code class="small">@e.EmpNo</code></td>
                        <td>
                            <a href="/hr/employee/detail/@e.Id" class="font-weight-bold text-dark">
                                @e.RealName
                            </a>
                            <small class="text-muted ml-1">@e.GenderText</small>
                        </td>
                        <td>@(e.DeptName ?? "-")</td>
                        <td>@(e.Phone ?? "-")</td>
                        <td>
                            <span class="badge @statusBadge[e.Status]">@e.StatusText</span>
                        </td>
                        <td class="small text-muted">@(e.EntryDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                        <td class="small text-muted">@(e.FormalDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                        <td>
                            <a href="/hr/employee/detail/@e.Id" class="btn btn-xs btn-info" title="详情">
                                <i class="fas fa-eye"></i>
                            </a>
                            @if (canEdit)
                            {
                                <button class="btn btn-xs btn-warning" onclick="openEditModal(@e.Id)" title="编辑">
                                    <i class="fas fa-edit"></i>
                                </button>
                            }
                            @if (canFormal && e.Status == 0)
                            {
                                <button class="btn btn-xs btn-success" onclick="doFormal(@e.Id, '@e.RealName')" title="转正">
                                    <i class="fas fa-user-check"></i>
                                </button>
                            }
                            @if (canLeave && e.Status != 2)
                            {
                                <button class="btn btn-xs btn-secondary" onclick="doLeave(@e.Id, '@e.RealName')" title="离职">
                                    <i class="fas fa-sign-out-alt"></i>
                                </button>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Items.Any())
                {
                    <tr><td colspan="8" class="text-center text-muted py-4">暂无数据</td></tr>
                }
            </tbody>
        </table>
    </div>
    <partial name="_Pagination" model="Model" />
</div>
</div></section>

<!-- 新增/编辑弹窗 -->
<div class="modal fade" id="empModal" tabindex="-1">
    <div class="modal-dialog modal-lg"><div class="modal-content">
        <div class="modal-header">
            <h5 class="modal-title" id="empModalTitle">新增员工</h5>
            <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
        </div>
        <div class="modal-body">
            <input type="hidden" id="empId">
            <div class="row">
                <div class="col-md-4">
                    <div class="form-group">
                        <label>姓名 <span class="text-danger">*</span></label>
                        <input type="text" id="empRealName" class="form-control">
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label>性别</label>
                        <select id="empGender" class="form-control">
                            <option value="1">男</option>
                            <option value="2">女</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label>手机号</label>
                        <input type="text" id="empPhone" class="form-control">
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-4">
                    <div class="form-group">
                        <label>邮箱</label>
                        <input type="email" id="empEmail" class="form-control">
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label>所属部门</label>
                        <select id="empDeptId" class="form-control">
                            <option value="">请选择</option>
                            @foreach (var d in ViewBag.Depts as List<EnterpriseMS.Services.DTOs.System.DeptTreeDto> ?? new())
                            {
                                <option value="@d.Id">@d.DeptName</option>
                                @foreach (var c in d.Children)
                                {
                                    <option value="@c.Id">&nbsp;&nbsp;└ @c.DeptName</option>
                                }
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label>入职日期</label>
                        <input type="date" id="empEntryDate" class="form-control">
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label>身份证号</label>
                        <input type="text" id="empIdCard" class="form-control" maxlength="18">
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label>试用期截止日</label>
                        <input type="date" id="empProbationEnd" class="form-control">
                    </div>
                </div>
            </div>
            <div class="form-group">
                <label>备注</label>
                <textarea id="empRemark" class="form-control" rows="2"></textarea>
            </div>
            <hr>
            <h6 class="text-muted mb-3">扩展信息</h6>
            <div class="row">
                <div class="col-md-4">
                    <div class="form-group">
                        <label>出生日期</label>
                        <input type="date" id="empBirthDate" class="form-control">
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label>籍贯</label>
                        <input type="text" id="empNativePlace" class="form-control" maxlength="50">
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label>学历</label>
                        <select id="empEducation" class="form-control">
                            <option value="">请选择</option>
                            @foreach (var ed in new[] { "高中", "大专", "本科", "硕士", "博士", "其他" })
                            {
                                <option value="@ed">@ed</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label>专业</label>
                        <input type="text" id="empMajor" class="form-control" maxlength="50">
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label>毕业院校</label>
                        <input type="text" id="empGraduateSchool" class="form-control" maxlength="100">
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label>现住址</label>
                        <input type="text" id="empAddress" class="form-control" maxlength="200">
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label>紧急联系人</label>
                        <input type="text" id="empEmergencyContact" class="form-control" maxlength="50">
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label>紧急联系电话</label>
                        <input type="text" id="empEmergencyPhone" class="form-control" maxlength="20">
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label>银行账号</label>
                        <input type="text" id="empBankAccount" class="form-control" maxlength="30">
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label>开户行</label>
                        <input type="text" id="empBankName" class="form-control" maxlength="100">
                    </div>
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-default" data-dismiss="modal">取消</button>
            <button type="button" class="btn btn-primary" onclick="saveEmp()">保存</button>
        </div>
    </div></div>
</div>

@section Scripts {
<script>
var antiForgery = '@Html.AntiForgeryToken()'.match(/value="([^"]+)"/)[1];

function openAddModal() {
    $('#empModalTitle').text('新增员工');
    $('#empId').val('');
    $('#empRealName,#empPhone,#empEmail,#empIdCard,#empRemark').val('');
    $('#empGender').val(1); $('#empDeptId').val('');
    $('#empEntryDate').val(new Date().toISOString().split('T')[0]);
    $('#empModal').modal('show');
}

function openEditModal(id) {
    var load = layer.load(1);
    $.get('/hr/employee/json/' + id, function(r) {
        layer.close(load);
        if (!r.success) { layer.msg(r.message, {icon:2}); return; }
        var d = r.data;
        $('#empModalTitle').text('编辑员工 - ' + d.realName);
        $('#empId').val(d.id);
        $('#empRealName').val(d.realName);
        $('#empGender').val(d.gender);
        $('#empPhone').val(d.phone || '');
        $('#empEmail').val(d.email || '');
        $('#empIdCard').val(d.idCard || '');
        $('#empDeptId').val(d.deptId || '');
        $('#empEntryDate').val(d.entryDate || '');
        $('#empProbationEnd').val(d.probationEndDate || '');
        $('#empRemark').val(d.remark || '');
        $('#empBirthDate').val(d.birthDate || '');
        $('#empNativePlace').val(d.nativePlace || '');
        $('#empEducation').val(d.education || '');
        $('#empMajor').val(d.major || '');
        $('#empGraduateSchool').val(d.graduateSchool || '');
        $('#empAddress').val(d.address || '');
        $('#empEmergencyContact').val(d.emergencyContact || '');
        $('#empEmergencyPhone').val(d.emergencyPhone || '');
        $('#empBankAccount').val(d.bankAccount || '');
        $('#empBankName').val(d.bankName || '');
        $('#empModal').modal('show');
    }).fail(function() {
        layer.closeAll('loading');
        layer.msg('加载失败', {icon:2});
    });
}

function saveEmp() {
    var id = $('#empId').val();
    var data = {
        Id: id || undefined, RealName: $('#empRealName').val(),
        Gender: parseInt($('#empGender').val()),
        Phone: $('#empPhone').val(), Email: $('#empEmail').val(),
        IdCard: $('#empIdCard').val(),
        DeptId: parseInt($('#empDeptId').val()) || null,
        EntryDate: $('#empEntryDate').val() || null,
        ProbationEndDate: $('#empProbationEnd').val() || null,
        Remark: $('#empRemark').val(),
        BirthDate: $('#empBirthDate').val() || null,
        NativePlace: $('#empNativePlace').val(),
        Education: $('#empEducation').val(),
        Major: $('#empMajor').val(),
        GraduateSchool: $('#empGraduateSchool').val(),
        Address: $('#empAddress').val(),
        EmergencyContact: $('#empEmergencyContact').val(),
        EmergencyPhone: $('#empEmergencyPhone').val(),
        BankAccount: $('#empBankAccount').val(),
        BankName: $('#empBankName').val()
    };
    if (!data.RealName) { layer.msg('请填写姓名', {icon:2}); return; }
    var url = id ? '/hr/employee/update' : '/hr/employee/create';
    var load = layer.load(1);
    $.ajax({ url, type:'POST', contentType:'application/json',
        headers:{'RequestVerificationToken': antiForgery},
        data: JSON.stringify(data),
        success: function(r) {
            layer.close(load);
            if (r.success) { $('#empModal').modal('hide'); layer.msg(r.message, {icon:1, time:1500}, ()=>location.reload()); }
            else layer.msg(r.message, {icon:2});
        }
    });
}

function doFormal(id, name) {
    layer.prompt({title: name + ' 转正日期', formType: 2}, function(val, i) {
        layer.close(i);
        $.post('/hr/employee/formal', {id, formalDate: val, __RequestVerificationToken: antiForgery}, function(r) {
            layer.msg(r.message, {icon: r.success?1:2, time:1500}, function() { if(r.success) location.reload(); });
        });
    });
}

function doLeave(id, name) {
    layer.prompt({title: name + ' 离职日期', formType: 2}, function(val, i) {
        layer.close(i);
        $.post('/hr/employee/leave', {id, leaveDate: val, __RequestVerificationToken: antiForgery}, function(r) {
            layer.msg(r.message, {icon: r.success?1:2, time:1500}, function() { if(r.success) location.reload(); });
        });
    });
}
</script>
}
